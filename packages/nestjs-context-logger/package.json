{
  "name": "@arkv/nestjs-context-logger",
  "version": "0.2.0",
  "description": "NestJS module for structured async-context logging powered by @arkv/logger",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nestjs",
    "logger",
    "structured",
    "context",
    "async-context",
    "typescript",
    "logging"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build:esm": "tsc -p tsconfig.build.esm.json",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:types": "tsc -p tsconfig.build.types.json",
    "build": "bun run --parallel build:esm build:cjs build:types",
    "postbuild": "echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@arkv/logger": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.2.2"
  },
  "author": {
    "name": "Petar Zarkov",
    "email": "pzarko1@gmail.com",
    "url": "https://github.com/petarzarkov"
  },
  "license": "MIT",
  "homepage": "https://github.com/petarzarkov/arkv/tree/main/packages/nestjs-context-logger#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/petarzarkov/arkv",
    "directory": "packages/nestjs-context-logger"
  }
}
